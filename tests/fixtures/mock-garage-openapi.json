{
  "openapi": "3.1.0",
  "info": {
    "title": "Garage Cloud API",
    "version": "2026-01"
  },
  "servers": [{ "url": "https://api.garage-cloud.test/v1" }],
  "paths": {
    "/customers": {
      "get": {
        "operationId": "listCustomers",
        "summary": "Lister les clients",
        "tags": ["Customers"],
        "security": [{ "oauth": ["customers:read"] }],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Customer" }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createCustomer",
        "summary": "Creer un client",
        "tags": ["Customers"],
        "security": [{ "oauth": ["customers:write"] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Customer" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Cree",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Customer" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://auth.garage-cloud.test/authorize",
            "tokenUrl": "https://auth.garage-cloud.test/token",
            "scopes": {
              "customers:read": "Lecture des clients",
              "customers:write": "Ecriture des clients"
            }
          }
        }
      }
    },
    "schemas": {
      "Customer": {
        "type": "object",
        "required": ["id", "email"],
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "name": { "type": "string" },
          "apiKey": { "type": "string", "example": "must-not-survive" }
        }
      }
    }
  },
  "webhooks": {
    "customerUpdated": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Customer" }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    }
  }
}
